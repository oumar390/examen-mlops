# =============================================================================
# Environment variables — copy this file to .env and customize values.
# .env is gitignored (never commit secrets).
# =============================================================================

# --- PostgreSQL backend for MLflow ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mlflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MLflow server ---
# Tracking URI used by client code (notebooks, training scripts, API)
MLFLOW_TRACKING_URI=http://localhost:5050
# Inside the docker network, services use http://mlflow:5000 instead.

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Streamlit ---
STREAMLIT_PORT=8501
# URL the Streamlit app uses to reach the API
API_URL=http://localhost:8000
